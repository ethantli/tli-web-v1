{
  "name": "true-legal-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy:cloudrun:build": "gcloud builds submit --tag gcr.io/PROJECT_ID/tli-web",
    "deploy:cloudrun:run": "gcloud run deploy tli-web --image gcr.io/PROJECT_ID/tli-web --platform managed --region us-central1 --allow-unauthenticated",
    "deploy:cloudrun": "npm run deploy:cloudrun:build && npm run deploy:cloudrun:run",
    "deploy:firebase": "npm run build && firebase deploy --only hosting",
    "deploy": "npm run deploy:firebase"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7"
  }
}
